# Production Environment Variables
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control

# Postgres container credentials (used by the `db` service in docker-compose.yml).
# POSTGRES_PASSWORD is REQUIRED — docker-compose will refuse to start without it.
POSTGRES_DB=cognitive_budget
POSTGRES_USER=cb_user
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD

# Full database connection string (overrides appsettings.json).
# In docker-compose this is derived from the POSTGRES_* values above, so you
# normally only set this when pointing at an EXTERNAL database (e.g. Neon).
# For local PostgreSQL: Host=localhost;Port=5432;Database=cognitive_budget;Username=cb_user;Password=YourSecurePassword;SSL Mode=Require
# For Neon: postgresql://<user>:<password>@<host>.neon.tech/<database>?sslmode=require&channel_binding=require
# ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=cognitive_budget;Username=cb_user;Password=YOUR_SECURE_PASSWORD

# For reverse proxy scenarios (nginx, Traefik), set to 'true' to disable
# built-in HTTPS redirect (TLS termination happens at proxy)
UseHttpsRedirection=false

# ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Production

# The user with this email is granted the Admin role on startup (if they exist).
# (The very first account to register also becomes admin automatically.)
Admin__Email=you@example.com

# Display culture for currency/number/date formatting (default en-ZA → R, period decimals).
App__Culture=en-ZA

# Apply EF migrations automatically on startup. Set to false for multi-instance
# deployments where you run migrations as a separate step.
ApplyMigrationsOnStartup=true

# Set to false to disable the daily trigger-analysis background job (e.g. on all
# but one instance when scaling out).
BackgroundService__Enabled=true

# Optional: Serilog minimum level
SERILOG_MINIMUM_LEVEL=Information

# Optional: pgAdmin (only used by the `dev` compose profile)
PGADMIN_EMAIL=admin@cognitivebudget.local
PGADMIN_PASSWORD=admin

# NOTE: For docker-compose, place this file in the project root.
# The docker-compose.yml will load these environment variables automatically.
