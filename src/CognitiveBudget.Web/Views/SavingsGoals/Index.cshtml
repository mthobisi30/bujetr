@model IEnumerable<SavingsGoal>
@{
    ViewData["Title"] = "Savings goals";
    string Money(decimal d) => d.ToString("C0");
}

<div class="page-header">
    <h2><i class="bi bi-piggy-bank text-primary"></i> Savings goals</h2>
    <a class="btn btn-primary" href="@Url.Action("Create")"><i class="bi bi-plus-lg"></i> New goal</a>
</div>

@if (!Model.Any())
{
    <div class="card"><div class="empty-state">
        <i class="bi bi-piggy-bank"></i>
        <h5>No savings goals yet</h5>
        <p>Set a target — a holiday, an emergency fund, a deposit — and track your progress.</p>
        <a class="btn btn-primary" href="@Url.Action("Create")"><i class="bi bi-plus-lg"></i> Create your first goal</a>
    </div></div>
}
else
{
    <div class="row g-3">
    @foreach (var g in Model)
    {
        var saved = g.Contributions.Sum(c => c.Amount);
        var pct = g.TargetAmount > 0 ? (int)Math.Min(100, (double)(saved / g.TargetAmount) * 100) : 0;
        var prioClass = g.Priority == SavingsPriority.High ? "danger" : g.Priority == SavingsPriority.Medium ? "warning" : "secondary";
        <div class="col-md-6">
            <div class="card h-100 @(g.IsCompleted ? "border-success" : "")"><div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <h6 class="card-title mb-1"><i class="bi bi-bullseye text-primary"></i> @g.Name</h6>
                    <span class="badge bg-@prioClass">@g.Priority</span>
                </div>
                @if (g.IsCompleted) { <span class="badge bg-success mb-2"><i class="bi bi-check-circle"></i> Completed</span> }
                <div class="d-flex justify-content-between"><span class="text-muted small">@Money(saved) of @Money(g.TargetAmount)</span><span class="small fw-semibold">@pct%</span></div>
                <div class="progress my-1" role="progressbar" aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
                    <div class="progress-bar @(g.IsCompleted ? "bg-success" : "bg-primary")" style="width:@pct%"></div>
                </div>
                @if (g.Deadline.HasValue) { <div class="small text-muted">Target date: @g.Deadline.Value.ToString("dd MMM yyyy")</div> }
                @if (!string.IsNullOrWhiteSpace(g.Notes)) { <div class="small text-muted">@g.Notes</div> }

                <form asp-action="AddContribution" method="post" class="row g-1 mt-2">
                    <input type="hidden" name="id" value="@g.Id" />
                    <div class="col"><input name="amount" type="number" step="0.01" class="form-control form-control-sm" placeholder="Add / withdraw (-)" /></div>
                    <div class="col-auto"><button class="btn btn-sm btn-outline-primary"><i class="bi bi-plus-circle"></i> Contribute</button></div>
                </form>
                <div class="mt-2 text-end">
                    <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Edit", new { id = g.Id })"><i class="bi bi-pencil"></i></a>
                    <form asp-action="Delete" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@g.Id" />
                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this goal?');"><i class="bi bi-trash"></i></button>
                    </form>
                </div>
            </div></div>
        </div>
    }
    </div>
}
