@model EditSavingsGoalViewModel
@{ ViewData["Title"] = "Edit savings goal"; var sym = System.Globalization.NumberFormatInfo.CurrentInfo.CurrencySymbol; }

<div class="page-header">
    <h2><i class="bi bi-piggy-bank text-primary"></i> Edit savings goal</h2>
    <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Index")"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="card"><div class="card-body">
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="TargetAmount" class="form-label">Target</label>
            <div class="input-group"><span class="input-group-text">@sym</span><input asp-for="TargetAmount" class="form-control" type="number" step="0.01" /></div>
            <span asp-validation-for="TargetAmount" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Priority" class="form-label">Priority</label>
            <select asp-for="Priority" class="form-select">
                @foreach (SavingsPriority p in Enum.GetValues<SavingsPriority>()) { <option value="@p" selected="@(p == Model.Priority)">@p</option> }
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="Deadline" class="form-label">Target date (optional)</label>
            <input asp-for="Deadline" class="form-control" type="date" />
        </div>
        <div class="col-12">
            <label asp-for="Notes" class="form-label">Notes (optional)</label>
            <input asp-for="Notes" class="form-control" />
        </div>
        <div class="col-12 form-check ms-2">
            <input asp-for="IsCompleted" class="form-check-input" />
            <label asp-for="IsCompleted" class="form-check-label">Mark as completed</label>
        </div>
    </div>
    <div class="mt-4"><button class="btn btn-primary"><i class="bi bi-check-lg"></i> Save</button>
        <a class="btn btn-link" href="@Url.Action("Index")">Cancel</a></div>
</form>
</div></div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
