@model CreateSavingsGoalViewModel
@{ ViewData["Title"] = "New savings goal"; var sym = System.Globalization.NumberFormatInfo.CurrentInfo.CurrencySymbol; }

<div class="form-card"><div class="card"><div class="card-body p-4 p-md-5">
    <div class="form-head"><span class="fh-ico"><i class="bi bi-piggy-bank"></i></span><div><h3>New savings goal</h3><p class="text-muted small mb-0">Set a target and track your progress.</p></div></div>
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Emergency fund" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="TargetAmount" class="form-label">Target</label>
                <div class="input-group"><span class="input-group-text">@sym</span><input asp-for="TargetAmount" class="form-control" type="number" step="0.01" /></div>
                <span asp-validation-for="TargetAmount" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Priority" class="form-label">Priority</label>
                <select asp-for="Priority" class="form-select">
                    @foreach (SavingsPriority p in Enum.GetValues<SavingsPriority>()) { <option value="@p">@p</option> }
                </select>
            </div>
            <div class="col-md-4">
                <label asp-for="Deadline" class="form-label">Target date (optional)</label>
                <input asp-for="Deadline" class="form-control" type="date" />
            </div>
            <div class="col-12">
                <label asp-for="Notes" class="form-label">Notes (optional)</label>
                <input asp-for="Notes" class="form-control" />
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create</button>
            <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Cancel</a>
        </div>
    </form>
</div></div></div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
