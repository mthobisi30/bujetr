@model EditBillViewModel
@{ ViewData["Title"] = "Edit bill"; var sym = System.Globalization.NumberFormatInfo.CurrentInfo.CurrencySymbol; }
<div class="form-card"><div class="card"><div class="card-body p-4 p-md-5">
    <div class="form-head"><span class="fh-ico"><i class="bi bi-receipt"></i></span><div><h3>Edit bill</h3><p class="text-muted small mb-0">Update the details of this bill.</p></div></div>
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-12 col-md-6">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="Amount" class="form-label"></label>
                <div class="input-group"><span class="input-group-text">@sym</span><input asp-for="Amount" class="form-control" type="number" step="0.01" /></div>
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="Category" class="form-label"></label>
                <input asp-for="Category" class="form-control" />
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="NextDueDate" class="form-label">Next due date</label>
                <input asp-for="NextDueDate" class="form-control" type="date" />
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="Recurrence" class="form-label">Repeats</label>
                <select asp-for="Recurrence" class="form-select">
                    @foreach (BillRecurrence r in Enum.GetValues<BillRecurrence>()) { <option value="@r" selected="@(r == Model.Recurrence)">@(((Enum)r).Humanize())</option> }
                </select>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="ReminderDaysBefore" class="form-label">Remind days before</label>
                <input asp-for="ReminderDaysBefore" class="form-control" type="number" min="0" max="60" />
            </div>
            <div class="col-12 form-check form-switch">
                <input asp-for="AutoPay" class="form-check-input" role="switch" />
                <label asp-for="AutoPay" class="form-check-label">Auto-pay this bill</label>
            </div>
            <div class="col-12 form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Active</label>
            </div>
        </div>
        <div class="form-actions"><button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save changes</button><a class="btn btn-outline-secondary" href="@Url.Action("Index")">Cancel</a></div>
    </form>
</div></div></div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
