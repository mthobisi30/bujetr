@model ReportsViewModel
@{
    ViewData["Title"] = "Reports";
    string Money(decimal d) => d.ToString("C0");
    var catColors = new[] { "#25e07e", "#8b5cf6", "#3b82f6", "#f59e0b", "#06b6d4", "#ec4899", "#10b981", "#9aa3b2" };
    var totalInc = Model.Series.Sum(s => s.Income);
    var totalExp = Model.Series.Sum(s => s.Expense);
    var avgRate = totalInc > 0 ? (int)Math.Round((double)((totalInc - totalExp) / totalInc) * 100) : 0;
    var library = new[]
    {
        ("Monthly Spending Summary","Summary","pill-green","#25e07e","bi-file-earmark-text", true),
        ("Income vs Expense","Analysis","pill-violet","#8b5cf6","bi-bar-chart", false),
        ("Cash Flow Trend","Trend","pill-cyan","#06b6d4","bi-graph-up", false),
        ("Category Breakdown","Breakdown","pill-amber","#f59e0b","bi-pie-chart", false),
        ("Savings & Debt Snapshot","Snapshot","pill-red","#ec4899","bi-clipboard-data", false),
        ("Full Transactions Export","Export","pill-gray","#9aa3b2","bi-download", true),
    };
}

<div class="hero">
    <div class="page-header">
        <div><h2>Insights</h2><p class="text-muted m-0">Monitor patterns, understand your money, and automate smarter financial decisions.</p></div>
        <a class="btn btn-primary" href="@Url.Action("ExportCsv")"><i class="bi bi-download"></i> Export CSV</a>
    </div>
    <partial name="_InsightsTabs" model="@("reports")" />
</div>

<!-- KPIs -->
<div class="row row-cols-2 row-cols-xl-4 g-3 my-1">
    <div class="col"><div class="card kpi h-100"><div class="d-flex justify-content-between"><div><div class="lbl">Months of Data</div><div class="val">@Model.Series.Count</div><div class="text-muted small">rolling window</div></div><span class="chip-ico"><i class="bi bi-calendar-range"></i></span></div></div></div>
    <div class="col"><div class="card kpi h-100"><div class="d-flex justify-content-between"><div><div class="lbl">Income (6 mo)</div><div class="val text-success" style="font-size:1.5rem;">@Money(totalInc)</div></div><span class="chip-ico"><i class="bi bi-arrow-down-left"></i></span></div></div></div>
    <div class="col"><div class="card kpi h-100"><div class="d-flex justify-content-between"><div><div class="lbl">Expenses (6 mo)</div><div class="val" style="font-size:1.5rem;">@Money(totalExp)</div></div><span class="chip-ico red"><i class="bi bi-arrow-up-right"></i></span></div></div></div>
    <div class="col"><div class="card kpi h-100"><div class="d-flex justify-content-between"><div><div class="lbl">Avg Savings Rate</div><div class="val">@avgRate%</div></div><span class="chip-ico cyan"><i class="bi bi-piggy-bank"></i></span></div></div></div>
</div>

<div class="dash-grid">
    <div class="dash-col">
        <div class="card"><div class="card-body p-0">
            <div class="d-flex justify-content-between align-items-center p-3 pb-2"><h6 class="card-title m-0"><i class="bi bi-collection"></i> Reports Library</h6></div>
            <div class="table-responsive"><table class="table table-hover align-middle mb-0">
                <thead><tr><th>Report</th><th>Type</th><th>Frequency</th><th>Coverage</th><th class="text-end">Action</th></tr></thead>
                <tbody>
                @foreach (var r in library)
                {
                    <tr>
                        <td><div class="d-flex align-items-center gap-2"><span style="width:2.1rem;height:2.1rem;border-radius:.6rem;display:grid;place-items:center;color:@r.Item4;background:color-mix(in srgb,@r.Item4 16%,transparent);"><i class="bi @r.Item5"></i></span><span class="fw-semibold">@r.Item1</span></div></td>
                        <td><span class="pill @r.Item3">@r.Item2</span></td>
                        <td class="text-muted small">On demand</td>
                        <td class="text-muted small">All accounts</td>
                        <td class="text-end">
                            @if (r.Item6) { <a class="btn btn-sm btn-outline-success" href="@Url.Action("ExportCsv")"><i class="bi bi-download"></i> Export</a> }
                            else { <a class="btn btn-sm btn-outline-secondary" href="#charts"><i class="bi bi-eye"></i> View</a> }
                        </td>
                    </tr>
                }
                </tbody>
            </table></div>
        </div></div>

        <div class="card" id="charts"><div class="card-body">
            <h6 class="card-title mb-3"><i class="bi bi-bar-chart-line"></i> Income vs Expense — last @Model.Series.Count months</h6>
            <canvas id="ieChart" height="130"></canvas>
        </div></div>
    </div>

    <div class="dash-col">
        <div class="card"><div class="card-body">
            <h6 class="card-title mb-3"><i class="bi bi-pie-chart"></i> Spending by Category</h6>
            @if (Model.Categories.Any())
            {
                <div class="d-flex justify-content-center"><div style="position:relative;width:170px;height:170px;">
                    <canvas id="catChart"></canvas>
                    <div style="position:absolute;inset:0;display:grid;place-items:center;text-align:center;pointer-events:none;"><div><div class="text-muted small">Total</div><div class="fw-bold">@Money(Model.Categories.Sum(c => c.Total))</div></div></div>
                </div></div>
                <div class="mt-3">@{ var i = 0; }
                @foreach (var c in Model.Categories.Take(6))
                {
                    var col = catColors[i % catColors.Length]; i++;
                    <div class="d-flex align-items-center justify-content-between py-1 small"><span><span class="d-inline-block rounded-circle me-2" style="width:.6rem;height:.6rem;background:@col;"></span>@c.Category</span><span class="text-muted">@c.PercentOfTotal.ToString("0")%</span></div>
                }
                </div>
            }
            else { <p class="text-muted small mb-0">No spending this month yet.</p> }
        </div></div>

        <div class="card"><div class="card-body">
            <h6 class="card-title mb-3"><i class="bi bi-clipboard-data"></i> Snapshot</h6>
            <div class="d-flex justify-content-between py-2 border-bottom" style="border-color:var(--line)!important;"><span class="text-muted small">This-month income</span><span class="fw-semibold text-success">@Money(Model.MonthIncome)</span></div>
            <div class="d-flex justify-content-between py-2 border-bottom" style="border-color:var(--line)!important;"><span class="text-muted small">This-month expense</span><span class="fw-semibold">@Money(Model.MonthExpense)</span></div>
            <div class="d-flex justify-content-between py-2 border-bottom" style="border-color:var(--line)!important;"><span class="text-muted small">Total saved</span><span class="fw-semibold text-success">@Money(Model.TotalSaved)</span></div>
            <div class="d-flex justify-content-between py-2"><span class="text-muted small">Total debt</span><span class="fw-semibold text-danger">@Money(Model.TotalDebt)</span></div>
        </div></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" crossorigin="anonymous"></script>
    <script>
        new Chart(document.getElementById('ieChart'), {
            type: 'bar',
            data: { labels: @Html.Raw(Json.Serialize(Model.Series.Select(s => s.Label))),
                datasets: [
                    { label: 'Income', data: @Html.Raw(Json.Serialize(Model.Series.Select(s => s.Income))), backgroundColor: 'rgba(37,224,126,.75)', borderRadius: 4 },
                    { label: 'Expenses', data: @Html.Raw(Json.Serialize(Model.Series.Select(s => s.Expense))), backgroundColor: 'rgba(239,68,68,.6)', borderRadius: 4 }
                ] },
            options: { plugins: { legend: { labels: { color: '#9aa3b2' } } }, scales: { x: { grid: { display: false }, ticks: { color: '#7c8694' } }, y: { grid: { color: 'rgba(255,255,255,.05)' }, ticks: { color: '#7c8694' } } } }
        });
        @if (Model.Categories.Any())
        {
            <text>
            new Chart(document.getElementById('catChart'), {
                type: 'doughnut',
                data: { labels: @Html.Raw(Json.Serialize(Model.Categories.Select(c => c.Category))),
                    datasets: [{ data: @Html.Raw(Json.Serialize(Model.Categories.Select(c => c.Total))), backgroundColor: @Html.Raw(Json.Serialize(catColors)), borderWidth: 0, hoverOffset: 6 }] },
                options: { cutout: '70%', plugins: { legend: { display: false } } }
            });
            </text>
        }
    </script>
}
