@model CalendarViewModel
@{
    ViewData["Title"] = "Calendar";
    var first = new DateTime(Model.Year, Model.Month, 1);
    var daysInMonth = DateTime.DaysInMonth(Model.Year, Model.Month);
    var startOffset = (int)first.DayOfWeek; // 0 = Sunday
    var prev = first.AddMonths(-1);
    var next = first.AddMonths(1);
    var today = DateTime.UtcNow.Date;
}

<div class="page-header">
    <h2><i class="bi bi-calendar3 text-primary"></i> Calendar</h2>
    <div class="d-flex align-items-center gap-2">
        <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Index", new { year = prev.Year, month = prev.Month })"><i class="bi bi-chevron-left"></i></a>
        <span class="fw-semibold">@first.ToString("MMMM yyyy")</span>
        <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Index", new { year = next.Year, month = next.Month })"><i class="bi bi-chevron-right"></i></a>
    </div>
</div>

<div class="card"><div class="card-body">
    <div class="row row-cols-7 g-1 text-center fw-semibold text-muted small mb-1">
        @foreach (var d in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
        {
            <div class="col">@d</div>
        }
    </div>
    <div class="row row-cols-7 g-1">
        @for (var i = 0; i < startOffset; i++)
        {
            <div class="col"><div class="p-2"></div></div>
        }
        @for (var day = 1; day <= daysInMonth; day++)
        {
            var date = new DateTime(Model.Year, Model.Month, day);
            Model.Days.TryGetValue(day, out var cell);
            <div class="col">
                <div class="border rounded p-1 h-100 @(date == today ? "border-primary" : "")" style="min-height:84px;">
                    <div class="small fw-semibold @(date == today ? "text-primary" : "")">@day</div>
                    @if (cell != null)
                    {
                        @if (cell.Spend > 0) { <div class="small text-danger">-@cell.Spend.ToString("C0")</div> }
                        @if (cell.Income > 0) { <div class="small text-success">+@cell.Income.ToString("C0")</div> }
                        @foreach (var b in cell.Bills)
                        {
                            <div class="badge bg-warning text-dark text-truncate d-block" title="@b.Name @b.Amount.ToString("C")" style="max-width:100%;"><i class="bi bi-receipt"></i> @b.Name</div>
                        }
                    }
                </div>
            </div>
        }
    </div>
    <div class="mt-3 small text-muted">
        <span class="text-danger">-amount</span> spent · <span class="text-success">+amount</span> income · <span class="badge bg-warning text-dark">bill</span> due
    </div>
</div></div>
