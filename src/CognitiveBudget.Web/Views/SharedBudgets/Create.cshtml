@model CreateSharedBudgetViewModel
@{ ViewData["Title"] = "New shared budget"; }

<div class="page-header">
    <h2><i class="bi bi-people text-primary"></i> New shared budget</h2>
    <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Index")"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="card"><div class="card-body">
<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3 col-md-6">
        <label asp-for="Name" class="form-label">Name</label>
        <input asp-for="Name" class="form-control" placeholder="e.g. Household, Flat 3B, Trip to Cape Town" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <button class="btn btn-primary"><i class="bi bi-check-lg"></i> Create</button>
    <a class="btn btn-link" href="@Url.Action("Index")">Cancel</a>
</form>
</div></div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
