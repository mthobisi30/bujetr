@model CreateSharedBudgetViewModel
@{ ViewData["Title"] = "New shared budget"; }

<div class="form-card"><div class="card"><div class="card-body p-4 p-md-5">
    <div class="form-head">
        <span class="fh-ico"><i class="bi bi-people"></i></span>
        <div><h3>New shared budget</h3><p class="text-muted small mb-0">Split expenses and reach goals together.</p></div>
    </div>
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-12 col-md-8">
                <label asp-for="Name" class="form-label">Name</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Household, Flat 3B, Trip to Cape Town" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create</button>
            <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Cancel</a>
        </div>
    </form>
</div></div></div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
