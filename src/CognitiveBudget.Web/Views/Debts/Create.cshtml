@model CreateDebtViewModel
@{ ViewData["Title"] = "Add debt"; var sym = System.Globalization.NumberFormatInfo.CurrentInfo.CurrencySymbol; }

<div class="page-header">
    <h2><i class="bi bi-credit-card-2-front text-primary"></i> Add debt</h2>
    <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Index")"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="card"><div class="card-body">
<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" placeholder="e.g. Car finance" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="DebtType" class="form-label">Type</label>
            <select asp-for="DebtType" class="form-select">
                @foreach (DebtType t in Enum.GetValues<DebtType>()) { <option value="@t">@(((Enum)t).Humanize())</option> }
            </select>
        </div>
        <div class="col-md-3">
            <label asp-for="OriginalBalance" class="form-label">Original balance</label>
            <div class="input-group"><span class="input-group-text">@sym</span><input asp-for="OriginalBalance" class="form-control" type="number" step="0.01" /></div>
        </div>
        <div class="col-md-3">
            <label asp-for="CurrentBalance" class="form-label">Current balance</label>
            <div class="input-group"><span class="input-group-text">@sym</span><input asp-for="CurrentBalance" class="form-control" type="number" step="0.01" /></div>
        </div>
        <div class="col-md-2">
            <label asp-for="InterestRate" class="form-label">APR %</label>
            <input asp-for="InterestRate" class="form-control" type="number" step="0.01" />
        </div>
        <div class="col-md-2">
            <label asp-for="MinimumPayment" class="form-label">Min payment</label>
            <div class="input-group"><span class="input-group-text">@sym</span><input asp-for="MinimumPayment" class="form-control" type="number" step="0.01" /></div>
        </div>
        <div class="col-md-2">
            <label asp-for="DueDayOfMonth" class="form-label">Due day</label>
            <input asp-for="DueDayOfMonth" class="form-control" type="number" min="1" max="31" />
        </div>
    </div>
    <div class="mt-4"><button class="btn btn-primary"><i class="bi bi-check-lg"></i> Add</button>
        <a class="btn btn-link" href="@Url.Action("Index")">Cancel</a></div>
</form>
</div></div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
