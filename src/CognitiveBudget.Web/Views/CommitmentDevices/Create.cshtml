@model CreateCommitmentDeviceViewModel
@{
    ViewData["Title"] = "New commitment rule";
}

<div class="page-header">
    <h2><i class="bi bi-shield-plus text-primary"></i> New commitment rule</h2>
    <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Index")"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="card"><div class="card-body">
<form asp-action="Create" method="post">
    <partial name="_DeviceFields" model="Model" />
    <div class="mt-4">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create rule</button>
        <a class="btn btn-link" href="@Url.Action("Index")">Cancel</a>
    </div>
</form>
</div></div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="/js/device-form.js"></script>
}
