@model EditCommitmentDeviceViewModel
@{
    ViewData["Title"] = "Edit commitment rule";
}

<div class="form-card wide"><div class="card"><div class="card-body p-4 p-md-5">
    <div class="form-head"><span class="fh-ico"><i class="bi bi-shield-check"></i></span><div><h3>Edit commitment rule</h3><p class="text-muted small mb-0">Adjust how this rule protects your budget.</p></div></div>
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <partial name="_DeviceFields" model="Model" />
        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save changes</button>
            <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Cancel</a>
        </div>
    </form>
</div></div></div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="/js/device-form.js"></script>
}
