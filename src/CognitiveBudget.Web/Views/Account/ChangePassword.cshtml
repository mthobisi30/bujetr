@model ChangePasswordViewModel
@{ ViewData["Title"] = "Change password"; }

<div style="max-width:460px;margin:3rem auto;">
  <div class="auth-form-card">
    <div class="text-center mb-4">
      <span class="brand mark mx-auto d-inline-grid" style="width:3rem;height:3rem;font-size:1.4rem;">C</span>
      <h2 class="fw-bold mt-3 mb-1">Change password</h2>
      <p class="text-muted small mb-0">Update your account password.</p>
    </div>
    <form asp-action="ChangePassword" method="post">
      <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
      <div class="mb-3 pw-wrap">
        <label asp-for="CurrentPassword" class="form-label">Current password</label>
        <input asp-for="CurrentPassword" class="form-control" type="password" autocomplete="current-password" data-pw />
        <button type="button" class="pw-eye" data-pw-toggle><i class="bi bi-eye"></i></button>
        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
      </div>
      <div class="mb-3 pw-wrap">
        <label asp-for="NewPassword" class="form-label">New password</label>
        <input asp-for="NewPassword" class="form-control" type="password" autocomplete="new-password" data-pw />
        <button type="button" class="pw-eye" data-pw-toggle><i class="bi bi-eye"></i></button>
        <small class="form-text text-muted">At least 10 characters, with an uppercase letter, a number and a symbol.</small>
        <span asp-validation-for="NewPassword" class="text-danger small d-block"></span>
      </div>
      <div class="mb-3 pw-wrap">
        <label asp-for="ConfirmPassword" class="form-label">Confirm new password</label>
        <input asp-for="ConfirmPassword" class="form-control" type="password" autocomplete="new-password" data-pw />
        <button type="button" class="pw-eye" data-pw-toggle><i class="bi bi-eye"></i></button>
        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
      </div>
      <button type="submit" class="btn btn-primary w-100 py-2"><i class="bi bi-check-lg"></i> Change password</button>
    </form>
    <p class="text-center text-muted mt-3 mb-0 small"><a href="@Url.Action("Login")" style="color:var(--g);">Back to sign in</a></p>
  </div>
</div>

@section Scripts {
  @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
  <script>document.querySelectorAll('[data-pw-toggle]').forEach(function(b){b.addEventListener('click',function(){var i=b.parentElement.querySelector('[data-pw]');if(!i)return;var s=i.type==='password';i.type=s?'text':'password';b.querySelector('i').className=s?'bi bi-eye-slash':'bi bi-eye';});});</script>
}
