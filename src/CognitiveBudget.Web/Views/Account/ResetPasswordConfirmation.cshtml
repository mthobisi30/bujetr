@{ ViewData["Title"] = "Password reset"; }

<div class="auth-card">
    <div class="card"><div class="card-body p-4 text-center">
        <i class="bi bi-check-circle text-success" style="font-size:2.5rem;"></i>
        <h4 class="mt-2">Password reset</h4>
        <p class="text-muted">Your password has been updated. You can now sign in.</p>
        <a class="btn btn-primary" href="@Url.Action("Login")"><i class="bi bi-box-arrow-in-right"></i> Sign in</a>
    </div></div>
</div>
