@{ ViewData["Title"] = "Password reset"; }

<div style="max-width:460px;margin:3rem auto;">
  <div class="auth-form-card text-center">
    <i class="bi bi-check-circle text-success" style="font-size:3rem;"></i>
    <h2 class="fw-bold mt-3 mb-1">Password reset</h2>
    <p class="text-muted small mb-4">Your password has been updated. You can now sign in.</p>
    <a class="btn btn-primary w-100 py-2" href="@Url.Action("Login")"><i class="bi bi-box-arrow-in-right"></i> Sign in</a>
  </div>
</div>
