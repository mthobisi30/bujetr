@{ ViewData["Title"] = "Check your email"; }

<div style="max-width:460px;margin:3rem auto;">
  <div class="auth-form-card text-center">
    <i class="bi bi-envelope-check text-success" style="font-size:3rem;"></i>
    <h2 class="fw-bold mt-3 mb-1">Check your email</h2>
    <p class="text-muted small mb-4">If an account exists for that address, a password reset link has been sent.</p>
    <a class="btn btn-primary w-100 py-2" href="@Url.Action("Login")"><i class="bi bi-box-arrow-in-right"></i> Back to sign in</a>
  </div>
</div>
