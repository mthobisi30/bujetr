@{ ViewData["Title"] = "Check your email"; }

<div class="auth-card">
    <div class="card"><div class="card-body p-4 text-center">
        <i class="bi bi-envelope-check text-success" style="font-size:2.5rem;"></i>
        <h4 class="mt-2">Check your email</h4>
        <p class="text-muted">If an account exists for that address, a password reset link has been sent.</p>
        <a class="btn btn-outline-secondary" href="@Url.Action("Login")">Back to sign in</a>
    </div></div>
</div>
