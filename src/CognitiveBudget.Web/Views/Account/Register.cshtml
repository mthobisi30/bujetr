@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-card">
    <div class="card"><div class="card-body p-4">
        <h3 class="text-center mb-1"><i class="bi bi-brain text-primary"></i> Create your account</h3>
        <p class="text-center text-muted mb-4">Start understanding your spending in minutes.</p>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
            <div class="row g-2">
                <div class="col-6">
                    <label asp-for="FirstName" class="form-label"></label>
                    <input asp-for="FirstName" class="form-control" autocomplete="given-name" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-6">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-control" autocomplete="family-name" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>
            <div class="mb-3 mt-2">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" type="email" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-2">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" type="password" autocomplete="new-password" />
                <small class="form-text text-muted">At least 10 characters, with an uppercase letter, a number and a symbol.</small>
                <span asp-validation-for="Password" class="text-danger d-block"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-person-plus"></i> Create account</button>
        </form>
        <p class="text-center text-muted mt-3 mb-0 small">
            Already have an account? <a href="@Url.Action("Login")">Sign in</a>
        </p>
    </div></div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
