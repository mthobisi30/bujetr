@model EditTransactionViewModel
@{
    ViewData["Title"] = "Edit transaction";
    var sym = System.Globalization.NumberFormatInfo.CurrentInfo.CurrencySymbol;
    var categories = ViewBag.Categories as IReadOnlyList<string> ?? new List<string>();
    var accounts = ViewBag.Accounts as IEnumerable<Account> ?? Enumerable.Empty<Account>();
}
<div class="form-card">
  <div class="card"><div class="card-body p-4 p-md-5">
    <div class="form-head">
      <span class="fh-ico"><i class="bi bi-pencil-square"></i></span>
      <div><h3>Edit transaction</h3><p class="text-muted small mb-0">Update the details of this transaction.</p></div>
    </div>
    <form asp-action="Edit" method="post">
      <input type="hidden" asp-for="Id" />
      <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
      <div class="row g-3">
        <div class="col-12 col-md-4">
          <label asp-for="Type" class="form-label">Type</label>
          <select asp-for="Type" class="form-select">
            <option value="Expense">Expense (money out)</option>
            <option value="Income">Income (money in)</option>
          </select>
        </div>
        <div class="col-12 col-md-4">
          <label asp-for="Amount" class="form-label"></label>
          <div class="input-group">
            <span class="input-group-text">@sym</span>
            <input asp-for="Amount" class="form-control" type="number" step="0.01" />
          </div>
          <span asp-validation-for="Amount" class="text-danger small"></span>
        </div>
        <div class="col-12 col-md-4">
          <label asp-for="TransactionDate" class="form-label"></label>
          <input asp-for="TransactionDate" class="form-control" type="date" />
          <span asp-validation-for="TransactionDate" class="text-danger small"></span>
        </div>
        <div class="col-12 col-md-4">
          <label asp-for="Category" class="form-label"></label>
          <input asp-for="Category" class="form-control" list="categoryList" autocomplete="off" />
          <datalist id="categoryList">
            @foreach (var c in categories) { <option value="@c"></option> }
          </datalist>
          <span asp-validation-for="Category" class="text-danger small"></span>
        </div>
        <div class="col-12">
          <label asp-for="Description" class="form-label"></label>
          <input asp-for="Description" class="form-control" />
          <span asp-validation-for="Description" class="text-danger small"></span>
        </div>
        <div class="col-12 col-md-3">
          <label asp-for="Merchant" class="form-label">Merchant <span class="text-muted">(optional)</span></label>
          <input asp-for="Merchant" class="form-control" />
        </div>
        <div class="col-12 col-md-3">
          <label asp-for="AccountId" class="form-label">Account <span class="text-muted">(optional)</span></label>
          <select asp-for="AccountId" class="form-select">
            <option value="">— none —</option>
            @foreach (var a in accounts) { <option value="@a.Id" selected="@(a.Id == Model.AccountId)">@a.Name</option> }
          </select>
        </div>
        <div class="col-12 col-md-6">
          <label asp-for="EmotionalState" class="form-label">Mood <span class="text-muted">(optional)</span></label>
          <select asp-for="EmotionalState" class="form-select">
            <option value="">— not set —</option>
            @foreach (EmotionalState state in Enum.GetValues<EmotionalState>())
            {
                <option value="@state" selected="@(state.Equals(Model.EmotionalState))">@(((Enum)state).Humanize())</option>
            }
          </select>
        </div>
      </div>

      @if (Model.NudgeResult != null || Model.Violations.Any())
      {
          var sev = Model.NudgeResult?.Severity == NudgeSeverity.StrongWarning ? "danger" : "warning";
          <div class="alert alert-@sev mt-3">
              <h6 class="alert-heading"><i class="bi bi-exclamation-triangle-fill"></i> Hold on a second</h6>
              @if (Model.NudgeResult != null) { <p class="mb-1">@Model.NudgeResult.Message</p> }
              @foreach (var v in Model.Violations) { <p class="mb-1"><i class="bi bi-shield-exclamation"></i> @v.Message</p> }
              <div class="form-check mt-2">
                  <input asp-for="ConfirmedDespiteWarning" class="form-check-input" />
                  <label asp-for="ConfirmedDespiteWarning" class="form-check-label">I understand and want to continue anyway</label>
              </div>
          </div>
      }

      <div class="form-actions">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save changes</button>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Cancel</a>
      </div>
    </form>

    <form asp-action="Delete" method="post" class="mt-3 pt-3 border-top">
      <input type="hidden" name="id" value="@Model.Id" />
      <button class="btn btn-outline-danger btn-sm" onclick="return confirm('Delete this transaction?');"><i class="bi bi-trash"></i> Delete transaction</button>
    </form>
  </div></div>
</div>
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
