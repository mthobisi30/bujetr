@model CreateTransactionViewModel
@{
    ViewData["Title"] = "Add transaction";
    var categories = ViewBag.Categories as IReadOnlyList<string> ?? new List<string>();
    var accounts = ViewBag.Accounts as IEnumerable<Account> ?? Enumerable.Empty<Account>();
}

<div class="page-header">
    <h2><i class="bi bi-plus-circle text-primary"></i> Add transaction</h2>
    <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Index")"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="card"><div class="card-body">
<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="Type" class="form-label">Type</label>
            <select asp-for="Type" class="form-select">
                <option value="Expense">Expense (money out)</option>
                <option value="Income">Income (money in)</option>
            </select>
            <small class="form-text text-muted">Nudges &amp; rules only apply to expenses.</small>
        </div>
        <div class="col-md-4">
            <label asp-for="Amount" class="form-label"></label>
            <div class="input-group">
                <span class="input-group-text">@System.Globalization.NumberFormatInfo.CurrentInfo.CurrencySymbol</span>
                <input asp-for="Amount" class="form-control" placeholder="0.00" />
            </div>
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="TransactionDate" class="form-label"></label>
            <input asp-for="TransactionDate" class="form-control" type="date" />
            <span asp-validation-for="TransactionDate" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Category" class="form-label"></label>
            <input asp-for="Category" class="form-control" list="categoryList" autocomplete="off" placeholder="e.g. Groceries" />
            <datalist id="categoryList">
                @foreach (var c in categories) { <option value="@c"></option> }
            </datalist>
            <span asp-validation-for="Category" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label"></label>
            <input asp-for="Description" class="form-control" />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Merchant" class="form-label">Merchant <span class="text-muted">(optional)</span></label>
            <input asp-for="Merchant" class="form-control" placeholder="e.g. Starbucks" />
        </div>
        <div class="col-md-3">
            <label asp-for="AccountId" class="form-label">Account <span class="text-muted">(optional)</span></label>
            <select asp-for="AccountId" class="form-select">
                <option value="">— none —</option>
                @foreach (var a in accounts) { <option value="@a.Id">@a.Name</option> }
            </select>
        </div>
        <div class="col-md-6">
            <label asp-for="EmotionalState" class="form-label">Mood <span class="text-muted">(optional)</span></label>
            <select asp-for="EmotionalState" class="form-select">
                <option value="">— not set —</option>
                @foreach (EmotionalState state in Enum.GetValues<EmotionalState>())
                {
                    <option value="@state">@(((Enum)state).Humanize())</option>
                }
            </select>
        </div>
    </div>

    @if (Model.NudgeResult != null || Model.Violations.Any())
    {
        var sev = Model.NudgeResult?.Severity == NudgeSeverity.StrongWarning ? "danger" : "warning";
        <div class="alert alert-@sev mt-3">
            <h6 class="alert-heading"><i class="bi bi-exclamation-triangle-fill"></i> Hold on a second</h6>
            @if (Model.NudgeResult != null) { <p class="mb-1">@Model.NudgeResult.Message</p> }
            @foreach (var v in Model.Violations) { <p class="mb-1"><i class="bi bi-shield-exclamation"></i> @v.Message</p> }
            <div class="form-check mt-2">
                <input asp-for="ConfirmedDespiteWarning" class="form-check-input" />
                <label asp-for="ConfirmedDespiteWarning" class="form-check-label">I understand and want to continue anyway</label>
            </div>
        </div>
    }

    <div class="mt-4">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save</button>
        <a class="btn btn-link" href="@Url.Action("Index")">Cancel</a>
    </div>
</form>
</div></div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
