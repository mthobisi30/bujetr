@model IEnumerable<CognitiveBudget.Web.Models.Domain.Transaction>
@{
    ViewData["Title"] = "Transactions";
}

<h2>Transactions</h2>
<p><a class="btn btn-primary" href="@Url.Action("Create")">Add new</a> <a class="btn btn-secondary" href="@Url.Action("Upload")">Import CSV</a></p>
<table class="table table-striped">
    <thead><tr><th>Date</th><th>Amount</th><th>Category</th><th>Description</th><th></th></tr></thead>
    <tbody>
    @foreach (var tx in Model)
    {
        <tr>
            <td>@tx.TransactionDate.ToShortDateString()</td>
            <td>@tx.Amount.ToString("C")</td>
            <td>@tx.Category</td>
            <td>@tx.Description</td>
            <td>
                <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Edit", new { id = tx.Id })">Edit</a>
                <form asp-action="Delete" method="post" style="display:inline">
                    <input type="hidden" name="id" value="@tx.Id" />
                    <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete?');">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>