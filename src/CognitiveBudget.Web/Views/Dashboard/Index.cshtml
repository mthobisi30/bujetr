@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    string Money(decimal d) => d.ToString("C0");

    var hour = DateTime.Now.Hour;
    var greet = hour < 12 ? "Good morning" : hour < 18 ? "Good afternoon" : "Good evening";
    var who = (User.Identity?.Name ?? "there").Split('@')[0];
    who = string.IsNullOrEmpty(who) ? "there" : char.ToUpper(who[0]) + who.Substring(1);

    var blimit = Model.Budget?.OverallLimit ?? Model.Budget?.TotalLimit ?? 0m;
    var bspent = Model.Budget?.TotalSpent ?? 0m;
    var bpct = blimit > 0 ? (int)Math.Min(100, (double)(bspent / blimit) * 100) : 0;
    var remaining = blimit - bspent;
    var daysLeft = Math.Max(1, DateTime.DaysInMonth(DateTime.UtcNow.Year, DateTime.UtcNow.Month) - DateTime.UtcNow.Day);
    var dailyLeft = remaining > 0 ? remaining / daysLeft : 0;

    var palette = new[] { "#25e07e", "#8b5cf6", "#f59e0b", "#06b6d4", "#ef4444", "#10b981", "#ec4899", "#9aa3b2" };
    var catTotal = Model.CategoryTotals.Sum(c => c.Total);
    var catColors = Enumerable.Range(0, Model.CategoryTotals.Count).Select(i => palette[i % palette.Length]).ToArray();
    var moodTotal = Model.MoodSpending.Sum(m => m.Total);

    var fgSaved = Model.FeaturedGoal?.Contributions.Sum(c => c.Amount) ?? 0m;
    var fgTarget = Model.FeaturedGoal?.TargetAmount ?? 0m;
    var fgPct = fgTarget > 0 ? (int)Math.Min(100, (double)(fgSaved / fgTarget) * 100) : 0;

    var maxDaily = Model.DailySpending.Count > 0 ? Math.Max(1m, Model.DailySpending.Max(p => p.Amount)) : 1m;

    Func<string, string> catPill = cat => (cat ?? "").ToLower() switch
    {
        "groceries" => "pill-green",
        "entertainment" => "pill-violet",
        "health" => "pill-red",
        "transport" => "pill-amber",
        "dining" or "eating out" => "pill-amber",
        "shopping" => "pill-cyan",
        "salary" or "side hustle" => "pill-green",
        "utilities" or "subscriptions" or "housing" => "pill-cyan",
        _ => "pill-gray"
    };
    Func<string, string> moodPill = c => c switch { "success" => "pill-green", "danger" => "pill-red", "warning" => "pill-amber", "secondary" => "pill-gray", _ => "pill-cyan" };
}

<div class="hero">
    <h1>@greet, @who</h1>
    <p>Here's your financial overview for @DateTime.UtcNow.ToString("MMMM yyyy")</p>
</div>

<div class="dash-grid">
    <!-- ════ MAIN COLUMN ════ -->
    <div class="dash-col">

        <!-- KPI cards -->
        <div class="row row-cols-2 row-cols-xl-4 g-3">
            <div class="col"><div class="card kpi h-100">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="chip-ico"><i class="bi bi-arrow-down-left"></i></span>
                    <span class="delta @(Model.IncomeDeltaPct >= 0 ? "delta-up" : "delta-down")"><i class="bi @(Model.IncomeDeltaPct >= 0 ? "bi-arrow-up-right" : "bi-arrow-down-right")"></i> @Math.Abs(Model.IncomeDeltaPct).ToString("0.0")%</span>
                </div>
                <div class="val">@Money(Model.TotalIncome)</div>
                <div class="lbl">Income</div>
            </div></div>
            <div class="col"><div class="card kpi h-100">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="chip-ico"><i class="bi bi-arrow-up-right"></i></span>
                    <span class="delta @(Model.SpendDeltaPct <= 0 ? "delta-up" : "delta-down")"><i class="bi @(Model.SpendDeltaPct <= 0 ? "bi-arrow-down-right" : "bi-arrow-up-right")"></i> @Math.Abs(Model.SpendDeltaPct).ToString("0.0")%</span>
                </div>
                <div class="val">@Money(Model.TotalSpend)</div>
                <div class="lbl">Spent</div>
            </div></div>
            <div class="col"><div class="card kpi h-100">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="chip-ico"><i class="bi bi-graph-up-arrow"></i></span>
                    <span class="delta @(Model.NetDeltaPct >= 0 ? "delta-up" : "delta-down")"><i class="bi @(Model.NetDeltaPct >= 0 ? "bi-arrow-up-right" : "bi-arrow-down-right")"></i> @Math.Abs(Model.NetDeltaPct).ToString("0.0")%</span>
                </div>
                <div class="val">@Money(Model.Net)</div>
                <div class="lbl">Net</div>
            </div></div>
            <div class="col"><div class="card kpi h-100">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="chip-ico"><i class="bi bi-pie-chart-fill"></i></span>
                    <span class="delta @(bpct >= 90 ? "delta-down" : "delta-up")">@bpct%</span>
                </div>
                <div class="val">@bpct%</div>
                <div class="lbl">Budget used · @Money(bspent) of @Money(blimit)</div>
                <div class="progress mt-2"><div class="progress-bar @(bpct >= 90 ? "bg-danger" : "bg-primary")" style="width:@bpct%"></div></div>
            </div></div>
        </div>

        <!-- Savings / Debt / Bills -->
        <div class="row g-3">
            <div class="col-md-4"><div class="card h-100"><div class="card-body">
                <h6 class="card-title"><i class="bi bi-bullseye"></i> Savings Goal</h6>
                <div class="d-flex align-items-center gap-3 mt-2">
                    <div class="ring" style="--p:@fgPct"><span>@fgPct%</span></div>
                    <div>
                        <div class="fs-5 fw-bold">@Money(fgSaved) <span class="text-muted fs-6 fw-normal">/ @Money(fgTarget)</span></div>
                        <div class="text-muted small">@(Model.FeaturedGoal?.Name ?? "No goal yet")</div>
                    </div>
                </div>
                <a class="btn btn-link p-0 mt-3 small" href="@Url.Action("Index","SavingsGoals")">Manage goals →</a>
            </div></div></div>

            <div class="col-md-4"><div class="card h-100"><div class="card-body">
                <h6 class="card-title"><i class="bi bi-credit-card-2-front text-danger"></i> Debt Outstanding</h6>
                <div class="mt-2" style="font-size:1.8rem;font-weight:800;color:#ff8b8b;">@Money(Model.TotalDebt)</div>
                <div class="text-muted small">@Model.DebtCount account@(Model.DebtCount == 1 ? "" : "s")</div>
                <a class="btn btn-link p-0 mt-3 small" href="@Url.Action("Index","Debts")">Manage debt →</a>
            </div></div></div>

            <div class="col-md-4"><div class="card h-100"><div class="card-body">
                <h6 class="card-title"><i class="bi bi-calendar-event"></i> Upcoming Bills</h6>
                @if (Model.UpcomingBills.Any())
                {
                    <ul class="list-unstyled small mb-2 mt-2">
                        @foreach (var b in Model.UpcomingBills)
                        {
                            <li class="d-flex justify-content-between py-1">
                                <span><span class="d-inline-block rounded-circle me-2" style="width:.45rem;height:.45rem;background:var(--g);"></span>@b.Name</span>
                                <span class="text-muted">@b.NextDueDate.ToString("dd MMM") · @Money(b.Amount)</span>
                            </li>
                        }
                    </ul>
                }
                else { <p class="text-muted small mt-2">No bills tracked.</p> }
                <a class="btn btn-link p-0 small" href="@Url.Action("Index","Bills")">View all bills →</a>
            </div></div></div>
        </div>

        <!-- Charts -->
        <div class="row g-3">
            <div class="col-12 col-xxl-7"><div class="card h-100"><div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="card-title m-0"><i class="bi bi-graph-up"></i> Spending Over Time</h6>
                    <span class="top-chip py-1 px-2" style="font-size:.78rem;">This month</span>
                </div>
                <canvas id="spendChart" height="160"></canvas>
            </div></div></div>

            <div class="col-12 col-xxl-5"><div class="card h-100"><div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="card-title m-0"><i class="bi bi-pie-chart"></i> Spending by Category</h6>
                    <span class="top-chip py-1 px-2" style="font-size:.78rem;">This month</span>
                </div>
                @if (Model.CategoryTotals.Any())
                {
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <div style="position:relative;width:160px;height:160px;flex:0 0 auto;">
                            <canvas id="catChart"></canvas>
                            <div style="position:absolute;inset:0;display:grid;place-items:center;text-align:center;pointer-events:none;">
                                <div><div class="text-muted small">Total</div><div class="fw-bold">@Money(catTotal)</div></div>
                            </div>
                        </div>
                        <div class="flex-grow-1" style="min-width:170px;">
                            @{ var ci = 0; }
                            @foreach (var c in Model.CategoryTotals.Take(8))
                            {
                                var col = catColors[ci]; ci++;
                                var pc = catTotal > 0 ? (int)Math.Round((double)(c.Total / catTotal) * 100) : 0;
                                <div class="d-flex align-items-center justify-content-between py-1" style="font-size:.83rem;">
                                    <span><span class="d-inline-block rounded-circle me-2" style="width:.6rem;height:.6rem;background:@col;"></span>@c.Category</span>
                                    <span class="text-muted">@pc% · @Money(c.Total)</span>
                                </div>
                            }
                        </div>
                    </div>
                }
                else { <p class="text-muted small mb-0">No spending yet this month.</p> }
            </div></div></div>
        </div>

        <!-- Recent transactions -->
        <div class="card"><div class="card-body p-0">
            <div class="d-flex justify-content-between align-items-center p-3 pb-2">
                <h6 class="card-title m-0"><i class="bi bi-clock-history"></i> Recent Transactions</h6>
                <a class="btn btn-outline-secondary btn-sm" href="@Url.Action("Index","Transactions")">View all</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead><tr><th>Date</th><th>Merchant</th><th>Category</th><th>Description</th><th class="text-end">Amount</th><th>Mood</th><th>Status</th></tr></thead>
                    <tbody>
                    @foreach (var t in Model.RecentTransactions)
                    {
                        <tr>
                            <td class="small text-nowrap">@t.TransactionDate.ToString("dd MMM yyyy")</td>
                            <td>@(string.IsNullOrEmpty(t.Merchant) ? "—" : t.Merchant)</td>
                            <td><span class="pill @catPill(t.Category)">@t.Category</span></td>
                            <td class="text-muted">@t.Description</td>
                            <td class="text-end fw-semibold @(t.Type == TransactionType.Income ? "text-success" : "")">@(t.Type == TransactionType.Income ? "+" : "")@t.Amount.ToString("C")</td>
                            <td>@if (t.EmotionalState != null) { <span class="d-inline-block rounded-circle bg-@(t.EmotionalState.MoodCssClass())" style="width:.8rem;height:.8rem;"></span> } else { <span class="text-muted">—</span> }</td>
                            <td>@if (t.EmotionalState != null) { <span class="pill @moodPill(t.EmotionalState.MoodCssClass())">@t.EmotionalState.Humanize()</span> } else { <span class="text-muted">—</span> }</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div></div>
    </div>

    <!-- ════ RIGHT RAIL ════ -->
    <div class="dash-col">

        <!-- Alerts -->
        <div class="card"><div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="card-title m-0"><i class="bi bi-bell"></i> Alerts</h6>
                <span class="pill pill-red">@Model.Alerts.Count</span>
            </div>
            @if (Model.Alerts.Any())
            {
                <ul class="list-unstyled small mb-2">
                    @foreach (var a in Model.Alerts.Take(5))
                    {
                        <li class="d-flex gap-2 py-1">
                            <span class="d-inline-block rounded-circle bg-@(a.Severity == "info" ? "info" : a.Severity) mt-1" style="width:.5rem;height:.5rem;flex:0 0 auto;"></span>
                            <span>@a.Message</span>
                        </li>
                    }
                </ul>
                <a class="btn btn-link p-0 small" href="@Url.Action("Index","Notifications")">View all alerts →</a>
            }
            else { <p class="text-muted small mb-0">You're all caught up.</p> }
        </div></div>

        <!-- Spending mood -->
        <div class="card"><div class="card-body">
            <h6 class="card-title mb-3"><i class="bi bi-emoji-smile"></i> Spending Mood</h6>
            @if (Model.MoodSpending.Any())
            {
                <div class="d-grid gap-2" style="grid-template-columns:1fr 1fr;">
                    @foreach (var m in Model.MoodSpending)
                    {
                        var pc = moodTotal > 0 ? (int)Math.Round((double)(m.Total / moodTotal) * 100) : 0;
                        <div class="mood-chip">
                            <span class="mi bg-@(m.Mood.MoodCssClass()) text-white"><i class="bi bi-emoji-smile"></i></span>
                            <span>@m.Mood?.Humanize()</span><span class="pct">@pc%</span>
                        </div>
                    }
                </div>
            }
            else { <p class="text-muted small mb-0">No mood data yet.</p> }
        </div></div>

        <!-- Budget progress -->
        <div class="card"><div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <h6 class="card-title m-0"><i class="bi bi-wallet2"></i> Budget Progress</h6>
                <span class="top-chip py-1 px-2" style="font-size:.78rem;">This month</span>
            </div>
            <div class="d-flex align-items-baseline gap-2"><span style="font-size:2.1rem;font-weight:800;color:var(--g);">@bpct%</span><span class="text-muted small">of @Money(blimit) used</span></div>
            <div class="progress my-2"><div class="progress-bar @(bpct >= 90 ? "bg-danger" : "bg-primary")" style="width:@bpct%"></div></div>
            <div class="d-flex justify-content-between small mb-3">
                <div><div class="text-muted">Remaining</div><div class="fw-semibold">@Money(remaining)</div></div>
                <div class="text-end"><div class="text-muted">Daily avg. left</div><div class="fw-semibold">@Money(dailyLeft)</div></div>
            </div>
            <div class="sparks">
                @foreach (var p in Model.DailySpending)
                {
                    var h = (int)Math.Round((double)(p.Amount / maxDaily) * 100);
                    <i style="height:@Math.Max(6, h)%"></i>
                }
            </div>
        </div></div>

        <!-- Smart insight -->
        <div class="card"><div class="card-body text-center">
            <h6 class="card-title text-start"><i class="bi bi-stars"></i> Smart Insight</h6>
            <div class="my-3" style="font-size:2.1rem;color:@(Model.InsightPositive ? "var(--g)" : "#f59e0b");filter:drop-shadow(0 0 16px @(Model.InsightPositive ? "var(--g-glow)" : "rgba(245,158,11,.4)"));">
                <i class="bi @(Model.InsightPositive ? "bi-hand-thumbs-up-fill" : "bi-exclamation-circle-fill")"></i>
            </div>
            <p class="mb-2 small">@Model.SmartInsight</p>
            <a class="btn btn-outline-primary btn-sm" href="@Url.Action("Index","Reports")">View Details</a>
        </div></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" crossorigin="anonymous"></script>
    <script>
        Chart.defaults.font.family = "Inter, system-ui, sans-serif";
        new Chart(document.getElementById('spendChart'), {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.DailySpending.Select(p => p.Day))),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(Model.DailySpending.Select(p => p.Amount))),
                    borderColor: '#25e07e', borderWidth: 2, tension: .4, fill: true, pointRadius: 0, pointHoverRadius: 5, pointHoverBackgroundColor: '#25e07e',
                    backgroundColor: function (ctx) { var c = ctx.chart.ctx; var g = c.createLinearGradient(0, 0, 0, 180); g.addColorStop(0, 'rgba(37,224,126,.35)'); g.addColorStop(1, 'rgba(37,224,126,0)'); return g; }
                }]
            },
            options: {
                plugins: { legend: { display: false }, tooltip: { backgroundColor: '#0d1219', borderColor: 'rgba(37,224,126,.4)', borderWidth: 1, padding: 10 } },
                scales: {
                    x: { grid: { display: false }, ticks: { color: '#5d6878', maxTicksLimit: 8 } },
                    y: { grid: { color: 'rgba(255,255,255,.05)' }, ticks: { color: '#5d6878' } }
                }
            }
        });
        @if (Model.CategoryTotals.Any())
        {
            <text>
            new Chart(document.getElementById('catChart'), {
                type: 'doughnut',
                data: { labels: @Html.Raw(Json.Serialize(Model.CategoryTotals.Select(c => c.Category))),
                        datasets: [{ data: @Html.Raw(Json.Serialize(Model.CategoryTotals.Select(c => c.Total))), backgroundColor: @Html.Raw(Json.Serialize(catColors)), borderWidth: 0, hoverOffset: 6 }] },
                options: { cutout: '70%', plugins: { legend: { display: false } } }
            });
            </text>
        }
    </script>
}
