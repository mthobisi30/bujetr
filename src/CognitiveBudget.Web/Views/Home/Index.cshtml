@{
    ViewData["Title"] = "Welcome";
    var authed = User.Identity?.IsAuthenticated == true;
    var bars = new[] { 40, 55, 48, 70, 60, 82, 65, 90, 72, 95, 78, 88 };
}

<div class="landing-hero">
    <span class="landing-badge"><i class="bi bi-stars"></i> Understand. Nudge. Take control.</span>
    <h1>Understand your spending triggers.<br>Get <span style="color:var(--g);">nudged</span> before impulse purchases.<br>Stay in control of your money.</h1>
    <p class="lead">CognitiveBudget maps your spending patterns, watches for the moments that matter, and nudges you with timely insights — so you spend with intention, not impulse.</p>

    <div class="d-flex gap-2 justify-content-center mt-4">
        @if (authed)
        {
            <a class="btn btn-primary btn-lg" href="@Url.Action("Index","Dashboard")"><i class="bi bi-speedometer2"></i> Go to dashboard</a>
        }
        else
        {
            <a class="btn btn-primary btn-lg" href="@Url.Action("Register","Account")"><i class="bi bi-rocket-takeoff"></i> Get started <i class="bi bi-arrow-right"></i></a>
            <a class="btn btn-outline-secondary btn-lg" href="#features"><i class="bi bi-play-circle"></i> See how it works</a>
        }
    </div>
    <div class="hero-pills"><span><i class="bi bi-check-circle-fill"></i> Private by design</span><span><i class="bi bi-check-circle-fill"></i> Bank-level security</span><span><i class="bi bi-check-circle-fill"></i> Cancel anytime</span></div>
</div>

<!-- Dashboard preview -->
<div class="preview-card">
    <div class="row g-3 align-items-center">
        <div class="col-lg-5">
            <div class="d-flex justify-content-between align-items-start">
                <div><div class="text-muted small">Spending Trend</div><div class="fw-bold" style="font-size:1.7rem;">R10,749</div>
                    <div class="small"><span class="text-muted">vs last month</span> <span class="text-success">+4.2%</span></div></div>
                <span class="top-chip py-1 px-2" style="font-size:.75rem;">This month</span>
            </div>
            <div class="sparks mt-3" style="height:64px;">@foreach (var b in bars) { <i style="height:@b%"></i> }</div>
        </div>
        <div class="col-lg-4">
            <div class="text-muted small mb-2">Spending by Category</div>
            <div class="d-flex align-items-center gap-3">
                <div class="mini-donut" style="background:conic-gradient(#25e07e 0 31%,#3b82f6 0 48%,#8b5cf6 0 61%,#ef4444 0 72%,#f59e0b 0 80%,#06b6d4 0 86%,#ec4899 0 91%,#9aa3b2 0 100%);">
                    <span class="text-center"><span class="d-block text-muted" style="font-size:.6rem;">Total</span><span style="font-size:.85rem;">R10,749</span></span>
                </div>
                <div class="small">
                    <div><span class="cal-dot" style="background:#25e07e;"></span>Groceries <span class="text-muted">31%</span></div>
                    <div><span class="cal-dot" style="background:#3b82f6;"></span>Shopping <span class="text-muted">17%</span></div>
                    <div><span class="cal-dot" style="background:#8b5cf6;"></span>Transport <span class="text-muted">13%</span></div>
                    <div><span class="cal-dot" style="background:#ef4444;"></span>Eating Out <span class="text-muted">11%</span></div>
                    <div><span class="cal-dot" style="background:#f59e0b;"></span>Utilities <span class="text-muted">8%</span></div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 text-center">
            <div class="text-muted small mb-2">Financial Health Score</div>
            <div class="ring mx-auto" style="--p:78;width:110px;height:110px;"><span style="font-size:1.5rem;">78</span></div>
            <div class="small text-success mt-1"><i class="bi bi-emoji-smile"></i> Good</div>
        </div>
    </div>
</div>

<!-- Features -->
<div class="row g-3 mt-2 landing-features" id="features">
    <div class="col-md-4"><div class="card h-100"><div class="card-body">
        <span class="fi auth-feature-icon" style="width:3rem;height:3rem;border-radius:1rem;display:grid;place-items:center;color:var(--g);background:var(--g-soft);box-shadow:inset 0 0 0 1px rgba(37,224,126,.3);"><i class="bi bi-activity"></i></span>
        <h5 class="mt-3">Spot your triggers</h5>
        <p class="text-muted small">We surface the times, days and moods when you tend to overspend.</p>
        <a class="fw-semibold text-decoration-none" style="color:var(--g);" href="@Url.Action("Register","Account")">See your patterns <i class="bi bi-arrow-right"></i></a>
    </div></div></div>
    <div class="col-md-4"><div class="card h-100"><div class="card-body">
        <span class="fi" style="width:3rem;height:3rem;border-radius:1rem;display:grid;place-items:center;color:var(--g);background:var(--g-soft);box-shadow:inset 0 0 0 1px rgba(37,224,126,.3);"><i class="bi bi-bell"></i></span>
        <h5 class="mt-3">Get nudged in the moment</h5>
        <p class="text-muted small">A heads-up before a purchase that's well above your usual.</p>
        <a class="fw-semibold text-decoration-none" style="color:var(--g);" href="@Url.Action("Register","Account")">Stay one step ahead <i class="bi bi-arrow-right"></i></a>
    </div></div></div>
    <div class="col-md-4"><div class="card h-100"><div class="card-body">
        <span class="fi" style="width:3rem;height:3rem;border-radius:1rem;display:grid;place-items:center;color:var(--g);background:var(--g-soft);box-shadow:inset 0 0 0 1px rgba(37,224,126,.3);"><i class="bi bi-shield-check"></i></span>
        <h5 class="mt-3">Commit to limits</h5>
        <p class="text-muted small">Set rules that add friction to the spending you want to curb.</p>
        <a class="fw-semibold text-decoration-none" style="color:var(--g);" href="@Url.Action("Register","Account")">Build better boundaries <i class="bi bi-arrow-right"></i></a>
    </div></div></div>
</div>

<div class="text-center text-muted small mt-4"><i class="bi bi-shield-check text-success me-1"></i> Trusted by users who want clarity, control and confidence.</div>
