@model CreateAccountViewModel
@{
    ViewData["Title"] = "Add account";
    var sym = System.Globalization.NumberFormatInfo.CurrentInfo.CurrencySymbol;
}

<div class="form-card">
  <div class="card"><div class="card-body p-4 p-md-5">
    <div class="form-head">
      <span class="fh-ico"><i class="bi bi-bank"></i></span>
      <div>
        <h3>Add account</h3>
        <p class="text-muted small mb-0">Create a new account to track its balance and activity.</p>
      </div>
    </div>
    <form asp-action="Create" method="post">
      <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
      <div class="row g-3">
        <div class="col-12 col-md-5">
          <label asp-for="Name" class="form-label"></label>
          <input asp-for="Name" class="form-control" placeholder="e.g. Capitec cheque" />
          <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-12 col-md-4">
          <label asp-for="AccountType" class="form-label">Type</label>
          <select asp-for="AccountType" class="form-select">
            @foreach (AccountType t in Enum.GetValues<AccountType>()) { <option value="@t">@(((Enum)t).Humanize())</option> }
          </select>
        </div>
        <div class="col-12 col-md-3">
          <label asp-for="StartingBalance" class="form-label">Starting balance</label>
          <div class="input-group"><span class="input-group-text">@sym</span><input asp-for="StartingBalance" class="form-control" type="number" step="0.01" /></div>
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Add</button>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Cancel</a>
      </div>
    </form>
  </div></div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
