@model List<CognitiveBudget.Web.Models.Domain.AuditLog>
@{
    ViewData["Title"] = "Admin · Audit log";
    Func<string, (string icon, string color)> actIcon = a => (a ?? "").ToLower() switch
    {
        var s when s.Contains("login") => ("bi-box-arrow-in-right", "#25e07e"),
        var s when s.Contains("register") || s.Contains("user") => ("bi-person-plus", "#8b5cf6"),
        var s when s.Contains("disable") || s.Contains("delete") || s.Contains("revoke") || s.Contains("lock") => ("bi-exclamation-triangle", "#f59e0b"),
        var s when s.Contains("role") || s.Contains("admin") || s.Contains("grant") => ("bi-shield-lock", "#06b6d4"),
        _ => ("bi-gear", "#9aa3b2")
    };
}

<div class="hero">
    <div class="page-header">
        <div>
            <h2>Audit Logs</h2>
            <p class="text-muted m-0">Recent system and account activity (most recent first).</p>
        </div>
        <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Index")"><i class="bi bi-arrow-left"></i> Back to admin</a>
    </div>
</div>

<div class="card"><div class="card-body p-0"><div class="table-responsive">
@if (!Model.Any())
{
    <div class="empty-state">
        <i class="bi bi-journal"></i>
        <h5>No audit entries yet</h5>
        <p>Audit events will appear here as users and admins take action.</p>
    </div>
}
else
{
    <table class="table table-hover align-middle mb-0">
        <thead><tr>
            <th scope="col">Time</th>
            <th scope="col">Action</th>
            <th scope="col">User</th>
            <th scope="col">Details</th>
        </tr></thead>
        <tbody>
        @foreach (var a in Model)
        {
            var ic = actIcon(a.Action);
            <tr>
                <td class="small text-muted text-nowrap">@a.Timestamp.ToString("dd MMM yyyy HH:mm")</td>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <span style="width:2rem;height:2rem;border-radius:.5rem;display:grid;place-items:center;color:@ic.color;background:color-mix(in srgb,@ic.color 16%,transparent);"><i class="bi @ic.icon"></i></span>
                        <span class="fw-semibold small">@a.Action</span>
                    </div>
                </td>
                <td class="small">@a.UserEmail</td>
                <td class="small text-muted">@a.Details</td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div></div>
