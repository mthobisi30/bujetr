@model IReadOnlyList<CognitiveBudget.Web.Services.Alert>
@{
    ViewData["Title"] = "Notifications";
    Func<string, (string pill, string color)> sev = s => (s ?? "").ToLower() switch
    {
        "danger" => ("pill-red", "#ef4444"),
        "warning" => ("pill-amber", "#f59e0b"),
        "success" => ("pill-green", "#25e07e"),
        _ => ("pill-cyan", "#06b6d4")
    };
    string Group(string s) => (s ?? "").ToLower() switch { "danger" or "warning" => "alerts", "success" => "reminders", _ => "updates" };
}

<div class="hero">
    <div class="page-header">
        <div><h2>Notifications</h2><p class="text-muted m-0">Stay updated with what matters most.</p></div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 my-3">
    <div class="btn-group btn-group-sm view-toggle" role="group" id="notifTabs">
        <button type="button" class="btn btn-outline-secondary active" data-filter="all">All</button>
        <button type="button" class="btn btn-outline-secondary" data-filter="alerts">Alerts</button>
        <button type="button" class="btn btn-outline-secondary" data-filter="updates">Updates</button>
        <button type="button" class="btn btn-outline-secondary" data-filter="reminders">Reminders</button>
    </div>
    <span class="text-muted small">@Model.Count notification@(Model.Count == 1 ? "" : "s")</span>
</div>

@if (!Model.Any())
{
    <div class="card"><div class="empty-state">
        <i class="bi bi-check2-circle"></i>
        <h5>You're all caught up</h5>
        <p>No overdue bills, budget overruns or approaching deadlines right now.</p>
    </div></div>
}
else
{
    <div class="card"><div class="card-body p-0" id="notifList">
        @foreach (var a in Model)
        {
            var v = sev(a.Severity);
            <a href="@a.Url" class="d-flex align-items-center gap-3 px-3 py-3 text-decoration-none notif-row" data-group="@Group(a.Severity)" style="border-bottom:1px solid var(--line);color:inherit;">
                <span style="width:2.6rem;height:2.6rem;border-radius:.8rem;display:grid;place-items:center;flex:0 0 auto;color:@v.color;background:color-mix(in srgb,@v.color 15%,transparent);"><i class="bi @a.Icon"></i></span>
                <div class="flex-grow-1 min-w-0"><div class="fw-semibold">@a.Message</div></div>
                <span class="pill @v.pill text-uppercase">@a.Severity</span>
                <i class="bi bi-chevron-right text-muted"></i>
            </a>
        }
    </div></div>
}

@section Scripts {
    <script>
        var tabs = document.getElementById('notifTabs');
        if (tabs) tabs.addEventListener('click', function (e) {
            var b = e.target.closest('[data-filter]'); if (!b) return;
            tabs.querySelectorAll('.btn').forEach(function (x) { x.classList.remove('active'); });
            b.classList.add('active');
            var f = b.getAttribute('data-filter');
            document.querySelectorAll('.notif-row').forEach(function (r) {
                r.style.display = (f === 'all' || r.getAttribute('data-group') === f) ? '' : 'none';
            });
        });
    </script>
}
