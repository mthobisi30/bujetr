@model IReadOnlyList<CognitiveBudget.Web.Services.Alert>
<li class="nav-item dropdown">
    <a class="nav-link position-relative" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" title="Notifications">
        <i class="bi bi-bell"></i>
        @if (Model.Count > 0)
        {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:.6rem;">
                @Model.Count<span class="visually-hidden">alerts</span>
            </span>
        }
    </a>
    <ul class="dropdown-menu dropdown-menu-end shadow" style="min-width:320px;max-height:420px;overflow:auto;">
        <li><h6 class="dropdown-header">Notifications</h6></li>
        @if (!Model.Any())
        {
            <li><span class="dropdown-item-text text-muted small">You're all caught up.</span></li>
        }
        else
        {
            @foreach (var a in Model.Take(8))
            {
                <li>
                    <a class="dropdown-item d-flex align-items-start gap-2 text-wrap" href="@a.Url">
                        <i class="bi @a.Icon text-@a.Severity mt-1"></i>
                        <span class="small">@a.Message</span>
                    </a>
                </li>
            }
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-center small" href="@Url.Action("Index","Notifications")">View all (@Model.Count)</a></li>
        }
    </ul>
</li>
