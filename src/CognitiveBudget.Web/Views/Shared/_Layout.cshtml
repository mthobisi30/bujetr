@{
    var currentController = ViewContext.RouteData.Values["controller"] as string;
    string NavActive(string controller) => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CognitiveBudget</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg cb-nav sticky-top">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")"><i class="bi bi-brain"></i> CognitiveBudget</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item"><a class="nav-link @NavActive("Dashboard")" aria-current="@(NavActive("Dashboard") == "active" ? "page" : null)" href="@Url.Action("Index","Dashboard")"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link @NavActive("Transactions")" aria-current="@(NavActive("Transactions") == "active" ? "page" : null)" href="@Url.Action("Index","Transactions")"><i class="bi bi-list-ul"></i> Transactions</a></li>
                        <li class="nav-item"><a class="nav-link @NavActive("Accounts")" aria-current="@(NavActive("Accounts") == "active" ? "page" : null)" href="@Url.Action("Index","Accounts")"><i class="bi bi-bank"></i> Accounts</a></li>
                        <li class="nav-item"><a class="nav-link @NavActive("Budgets")" aria-current="@(NavActive("Budgets") == "active" ? "page" : null)" href="@Url.Action("Index","Budgets")"><i class="bi bi-wallet2"></i> Budget</a></li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @((NavActive("SavingsGoals") + NavActive("Bills") + NavActive("Debts") + NavActive("SharedBudgets")).Contains("active") ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown"><i class="bi bi-clipboard-check"></i> Planning</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item @NavActive("SavingsGoals")" href="@Url.Action("Index","SavingsGoals")"><i class="bi bi-piggy-bank"></i> Savings goals</a></li>
                                <li><a class="dropdown-item @NavActive("Bills")" href="@Url.Action("Index","Bills")"><i class="bi bi-receipt"></i> Bills</a></li>
                                <li><a class="dropdown-item @NavActive("Debts")" href="@Url.Action("Index","Debts")"><i class="bi bi-credit-card-2-front"></i> Debt</a></li>
                                <li><a class="dropdown-item @NavActive("SharedBudgets")" href="@Url.Action("Index","SharedBudgets")"><i class="bi bi-people"></i> Shared budgets</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @((NavActive("Reports") + NavActive("Calendar") + NavActive("SpendingTriggers") + NavActive("CommitmentDevices")).Contains("active") ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown"><i class="bi bi-graph-up"></i> Insights</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item @NavActive("Reports")" href="@Url.Action("Index","Reports")"><i class="bi bi-bar-chart-line"></i> Reports</a></li>
                                <li><a class="dropdown-item @NavActive("Calendar")" href="@Url.Action("Index","Calendar")"><i class="bi bi-calendar3"></i> Calendar</a></li>
                                <li><a class="dropdown-item @NavActive("SpendingTriggers")" href="@Url.Action("Index","SpendingTriggers")"><i class="bi bi-lightning-charge"></i> Triggers</a></li>
                                <li><a class="dropdown-item @NavActive("CommitmentDevices")" href="@Url.Action("Index","CommitmentDevices")"><i class="bi bi-shield-check"></i> Rules</a></li>
                            </ul>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav align-items-lg-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @await Component.InvokeAsync("Alerts")
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle"></i> @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><a class="dropdown-item @NavActive("Admin")" href="@Url.Action("Index","Admin")"><i class="bi bi-gear-wide-connected"></i> Admin</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                }
                                <li><a class="dropdown-item" href="@Url.Action("ChangePassword","Account")"><i class="bi bi-shield-lock"></i> Change password</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form method="post" asp-controller="Account" asp-action="Logout">
                                        <button type="submit" class="dropdown-item"><i class="bi bi-box-arrow-right"></i> Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Login","Account")">Login</a></li>
                        <li class="nav-item"><a class="btn btn-sm btn-primary ms-lg-2" href="@Url.Action("Register","Account")">Get started</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-1"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-1"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @RenderBody()

        <footer class="cb-footer">
            CognitiveBudget — understand your spending, beat the impulse.
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
